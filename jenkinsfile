pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/yourusername/website.git'
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                rm -rf /var/www/html/*
                cp -r * /var/www/html/
                '''
stage('Deploy') {
    steps {
        sh '''
        pkill -f "python3 -m http.server" || true
        nohup python3 -m http.server 8081 &
        '''
    }
}
            }
        }
    }
}
